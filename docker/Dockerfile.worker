FROM python:3.11-slim

# Install uv (much faster than pip)
COPY --from=ghcr.io/astral-sh/uv:latest /uv /uvx /bin/

WORKDIR /app

# System deps — Rust/Cargo required to compile base2048 (garak transitive dep)
RUN apt-get update \
    && apt-get install -y --no-install-recommends \
       -o Acquire::Retries=5 \
       gcc libpq-dev git rustc cargo \
    && rm -rf /var/lib/apt/lists/*

# ── Dependency layer (cached until pyproject.toml changes) ───────────
COPY pyproject.toml ./
RUN mkdir -p src/garakboard && touch src/garakboard/__init__.py
RUN uv pip install --system --no-cache ".[worker,dev]"

# ── Application layer ────────────────────────────────────────────────
COPY src/ ./src/
RUN uv pip install --system --no-deps --no-cache --reinstall-package garakboard .

ENV PYTHONUNBUFFERED=1

# Default: run the Celery worker
CMD ["celery", "-A", "garakboard.worker.celery_app:celery_app", "worker", "--loglevel=info", "--concurrency=2"]
