# Copy this file to docker/.env and fill in real values
# Usage: docker compose --env-file docker/.env -f docker/docker-compose.yml up

# Required
OPENROUTER_API_KEY=sk-or-v1-your-key-here
POSTGRES_PASSWORD=changeme-use-a-strong-password

# Optional overrides (defaults shown)
OPENROUTER_RPM_LIMIT=60
GARAK_PARALLEL_ATTEMPTS=10
GARAK_SOFT_PROBE_PROMPT_CAP=50
