# PostgreSQL — for local dev (services run on host) use localhost
# In Docker, DATABASE_URL is injected via docker-compose.yml using the service name "postgres"
DATABASE_URL=postgresql://garakboard:changeme@localhost:5432/garakboard

# Redis — for local dev use localhost
# In Docker, REDIS_URL is injected via docker-compose.yml using the service name "redis"
REDIS_URL=redis://localhost:6379/0

# OpenRouter — required, no default
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# garak tuning — adjust to match your OpenRouter plan tier
# Free tier is typically ~60 RPM; paid plans allow more
OPENROUTER_RPM_LIMIT=60
GARAK_PARALLEL_ATTEMPTS=10
GARAK_SOFT_PROBE_PROMPT_CAP=50

# API server
API_HOST=0.0.0.0
API_PORT=8000

# Gradio — for local dev use localhost; in Docker use the API container service name "api"
GRADIO_SERVER_PORT=7860
API_BASE_URL=http://localhost:8000

# HuggingFace Dataset sync — optional, only needed for export/import scripts
# HF_DATASET_REPO=your-username/open-llm-sec-leaderboard
# HF_TOKEN=hf_your_token_here
